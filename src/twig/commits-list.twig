{% if commits %}
    {% for date, commit in commits %}
        <div class="card">
            <div class="card-header">
                {{ date | format_date_long }}
            </div>
            <ul class="list-group list-group-striped list-group-flush">
                {% for item in commit %}
                    <li class="list-group-item p3x-gitlist-commits-list">
                        <div class="float-end p3x-gitlist-button" style="text-align: right;">
                            <a class="btn btn-primary btn-sm"
                               href="{{ path('branch', {repo: repo, branch: item.hash}) }}"
                               title="{{ 'commit.list.browse.tooltip'|t }}"><span class="fa fa-list-alt"></span>&nbsp;{{ 'commit.list.browse'|t }}</a>

                            <a class="btn btn-primary default btn-sm"
                               href="{{ path('commit', {repo: repo, commit: item.hash}) }}"><i
                                    class="far fa-chart-bar"></i>&nbsp;{{ 'commit.list.changes'|t }}</a>

                        </div>

                        <div class="media">
                            <div class="media-left">
                                <a>
                                    <img class="media-object" src="{{ avatar(item.author.email, 40) }}"/>
                                </a>
                            </div>
                            <div
                                class="media-body p3x-gitlist-commits-list-message p3x-gitlist-markdown-clear-fix">{{ item.message }}</div>
                        </div>
                        <div class="clearfix"></div>
                        <div class="float-end p3x-gitlist-button" style="text-align: right;">
                            <div style="margin-top: 5px; opacity: 0.5;">
                                <span class="d-none d-sm-block">
                                    <a href="javascript:void(0)" class="p3x-gitlist-copy-hash" data-hash="{{ item.hash }}" title="{{ 'js.copy_hash'|t }}"><i class="far fa-copy"></i></a>
                                    {{ item.hash }}
                                </span>
                                <span class="d-none d-md-block d-none d-lg-block d-none d-xl-block">{{ item.shortHash }}</span>
                            </div>
                        </div>

                        <div class="float-start">
                            <a href="mailto:{{ item.author.email }}">{{ item.author.name }}</a> {{ 'commit.authored'|t }},
                            {{ 'commit.on'|t }} <time datetime="{{ item.date | format_date_iso }}">{{ item.date | format_date }}</time>
                            {% if item.author.email != item.commiter.email %}
                                &bull; <a
                                href="mailto:{{ item.commiter.email }}">{{ item.commiter.name }}</a> {{ 'commit.committed_on'|t }} <time datetime="{{ item.commiterDate | format_date_iso }}">{{ item.commiterDate | format_date }}</time>
                            {% endif %}
                        </div>
                        <div class="clearfix"></div>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endfor %}
{% else %}

    <h4 class="p3x-gitlist-commit-list-no-more-commit">
        {{ 'commit.list.no_more'|t }}
    </h4>

{% endif %}

{% if page != 'searchcommits' %}
    <div id="p3x-gitlist-pager-bottom">
        {% if pager.current < pager.last - 1 %}
            <a id="p3x-gitlist-commit-list-next" class="btn btn-secondary" href="?page={{ pager.next }}">
                {{ 'commit.list.older_next'|t }} <i class="fas fa-chevron-right"></i>
            </a>
        {% endif %}
    </div>
{% endif %}

<script type="text/javascript">
    if (document.body.id === '') {
        location.reload()
    }
</script>

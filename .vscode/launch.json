{
    "version": "0.2.0",
    "configurations": [
        {
            "outputCapture": "std",
            "type": "node",
            "request": "launch",
            "name": "npm run watch",
            "args": [
                "run",
                "watch"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "cwd": "${workspaceRoot}",
            "program": "/usr/bin/npm"
        },
        {
            "name": "Listen for Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "/app": "${workspaceFolder}"
            },
            "log": true
        }
    ]
}
